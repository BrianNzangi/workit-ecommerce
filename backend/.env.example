DATABASE_URL=postgresql://postgres:password@localhost:5432/workit-db
BETTER_AUTH_SECRET=replace_with_secure_secret
BETTER_AUTH_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3002
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
# Optional in production for cross-subdomain sessions (e.g., .workit.co.ke)
BETTER_AUTH_COOKIE_DOMAIN=
# Keeps admin/backend sessions isolated from storefront cookies on same host.
BETTER_AUTH_COOKIE_PREFIX=admin-auth
# Storefront cookie prefix used by Next.js Better Auth.
STOREFRONT_AUTH_COOKIE_PREFIX=store-auth
# CSRF protection (optional overrides)
CSRF_COOKIE_NAME=XSRF-TOKEN
CSRF_HEADER_NAMES=x-xsrf-token,x-csrf-token,csrf-token
PRINT_ROUTES=false
PORT=3001
NODE_ENV=development

# Optional: Algolia (enables product search indexing + query)
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_ADMIN_API_KEY=your_algolia_admin_api_key
ALGOLIA_PRODUCTS_INDEX=products
