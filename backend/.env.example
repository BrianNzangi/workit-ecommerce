DATABASE_URL=postgresql://postgres:password@localhost:5432/workit-db
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
PRINT_ROUTES=false

# S3 / R2 storage
S3_ENDPOINT=https://6f7354fca326fc3c6e71124a139c5bf9.r2.cloudflarestorage.com
S3_BUCKET=workit
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
S3_AUTO_CREATE_BUCKET=false
PUBLIC_MEDIA_URL=https://media.workit.co.ke/uploads

# Redis
REDIS_URL=redis://localhost:6379

# Typesense Search
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=workit-typesense-api-key
TYPESENSE_PRODUCTS_COLLECTION=products
TYPESENSE_REINDEX_SCHEDULE_ENABLED=true
TYPESENSE_REINDEX_INTERVAL_MS=21600000

# Feature flags - toggle DDD implementations per bounded context
USE_DDD_ORDER_MANAGEMENT=true
USE_DDD_CATALOG=true
USE_DDD_CUSTOMER=true
USE_DDD_MARKETING=true
USE_DDD_FULFILLMENT=true
