NODE_ENV=development
PORT=3002
HOSTNAME=0.0.0.0

DATABASE_URL=postgresql://postgres:password@localhost:5432/workit-db

NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
BACKEND_API_URL=http://localhost:3001

# Keep auth same-origin by default (admin domain) to avoid cross-domain cookie issues.
# Example production value: https://admin.workit.co.ke
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3002
NEXT_PUBLIC_AUTH_BASE_PATH=/api/auth
NEXT_PUBLIC_AUTH_COOKIE_PREFIX=admin-auth
NEXT_PUBLIC_ADMIN_BASE_URL=http://localhost:3002

BETTER_AUTH_SECRET=replace_with_secure_secret
BETTER_AUTH_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3002
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Storefront browser analytics and Meta Conversions API vars belong in frontend/.env.local.
# Example: Google tag, GTM, META_PIXEL_ID, META_CONVERSIONS_ACCESS_TOKEN
