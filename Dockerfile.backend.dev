FROM node:22-alpine

RUN apk add --no-cache libc6-compat python3 make g++ bash
RUN corepack enable && corepack prepare pnpm@10.28.2 --activate
WORKDIR /app

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY backend/package.json ./backend/
COPY packages/db/package.json ./packages/db/
COPY packages/db/tsconfig.json ./packages/db/
COPY packages/db/drizzle.config.ts ./packages/db/
COPY packages/db/src ./packages/db/src
COPY packages/validation/package.json ./packages/validation/
COPY packages/validation/tsconfig.json ./packages/validation/
COPY packages/validation/src ./packages/validation/src
COPY backend/src ./backend/src
COPY backend/tsconfig.json ./backend/

RUN pnpm install --no-frozen-lockfile --filter=@workit/backend...

EXPOSE 3001
CMD ["sh", "-c", "pnpm --filter=@workit/db build && pnpm --filter=@workit/db push && pnpm --filter=@workit/validation build && npx tsx watch backend/src/server.ts"]
